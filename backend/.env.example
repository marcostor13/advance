# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/advance-group?retryWrites=true&w=majority

# App
PORT=3000
NODE_ENV=development

# CORS (comma-separated list of allowed origins; localhost:4200 is always allowed outside production)
FRONTEND_URL=http://localhost:4200,https://your-production-domain.com

# SMTP (Gmail) — used for password recovery and temp-password emails
# SMTP_USER: your Gmail address. SMTP_PASS: a 16-char Gmail "App Password" (requires 2FA enabled), NOT your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM="Advance Group <your-email@gmail.com>"

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES=1d

# Seed admin
ADMIN_EMAIL=admin@advancegroup.pe
ADMIN_PASSWORD=Admin123456!

# NVIDIA API (build.nvidia.com / integrate.api.nvidia.com) — powers the AI chat assistant
NVIDIA_API_KEY=your_nvidia_api_key_here
